# URL Redirect Map — config (all optional; copy to .env only if you need to override).
CORS_ORIGINS=http://localhost:5175

# SSRF guard: reject URLs that resolve to private/loopback/internal IPs (cloud metadata,
# RFC1918, localhost). Keep TRUE on any shared machine; set false only for an internal-only run.
REDIRECT_SSRF_BLOCK_PRIVATE=true

# Optional host allowlist — comma-separated, exact host or ".suffix" (e.g. ".wha-industrialestate.com").
# Empty = any public host allowed.
REDIRECT_URL_ALLOWLIST=
