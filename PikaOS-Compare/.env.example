# Website Compare — config (all optional; copy to .env only if you need to override).
# Ports: frontend 5174 / backend 8001 (registry: PiKaOs-docs/docs/architecture/ports.md — must not clash with the main stack).
CORS_ORIGINS=http://localhost:5174

# SSRF guard: reject URLs that resolve to private/loopback/internal IPs (cloud metadata,
# RFC1918, localhost). Keep TRUE on any shared machine; set false only for an internal-only run.
COMPARE_SSRF_BLOCK_PRIVATE=true

# Optional host allowlist — comma-separated, exact host or ".suffix" (e.g. ".ratch.co.th").
# Empty = any public host allowed.
COMPARE_URL_ALLOWLIST=
